# Database
# For local development: mongodb://localhost:27017/ai-job-portal
# For production: mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-job-portal
MONGODB_URI=mongodb://localhost:27017/ai-job-portal

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for OAuth callbacks and CORS)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=AI Job Portal <noreply@aijobportal.com>

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Update this to your deployed backend URL in production
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback